{
  "name": "developer-in-a-day-demo",
  "version": "1.0.0",
  "description": "End-to-end DevSecOps platform demo: Developer-in-a-Day Happy Path",
  "main": "src/app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage --forceExit",
    "test:unit": "jest --testPathPattern=__tests__ --coverage --forceExit",
    "lint": "eslint src/ --max-warnings 0",
    "lint:sarif": "eslint src/ --format @microsoft/eslint-formatter-sarif --output-file eslint-results.sarif; exit 0",
    "license-check": "license-checker --onlyAllow \"MIT;Apache-2.0;ISC;BSD-2-Clause;BSD-3-Clause;0BSD;Unlicense;CC0-1.0;Python-2.0;CC-BY-3.0;CC-BY-4.0;BlueOak-1.0.0\" --excludePrivatePackages --excludePackages \"jschardet@3.1.4;spdx-ranges@2.1.1;type-fest@0.20.2;type-fest@0.21.3\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^3.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "license-checker": "^25.0.1",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
